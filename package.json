{
  "name": "gittree",
  "version": "1.0.0",
  "description": "GitTree - Visualizador de Estrutura GitHub",
  "main": "index.html",
  "scripts": {
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "generate-robots": "node scripts/generate-robots.js",
    "generate-locales": "node scripts/generate-locales.js",
    "generate-seo": "npm run generate-sitemap && npm run generate-robots",
    "build:css": "tailwindcss -i css/tailwind-input.css -o tailwind-output.css --minify",
    "build": "npm run generate-locales && npm run generate-seo && npm run build:css",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoaoClaudiano/gittree.git"
  },
  "keywords": [
    "github",
    "tree",
    "visualizer",
    "repository",
    "structure"
  ],
  "author": "João Claudiano",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JoaoClaudiano/gittree/issues"
  },
  "homepage": "https://github.com/JoaoClaudiano/gittree#readme",
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
